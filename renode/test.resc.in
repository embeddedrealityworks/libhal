# Renode test setup script for @mcu_name@
# Generated by Meson configure_file — do not edit
#
# Loaded by renode-test (Robot Framework) via test.robot.
# Can also be run standalone:
#   renode --console --disable-gui --script <this_file>

$elf  ?= @elf_path@
$repl ?= @repl_path@
$svd  ?= @svd_path@

mach create "@mcu_name@"
machine LoadPlatformDescription $repl

# SVD adds peripheral register models on top of the minimal platform
sysbus LoadSVD $svd

# Route ARM semihosting output/exit through the CPU
cpu EnableSemihosting

sysbus LoadELF $elf
sysbus.cpu PC `sysbus GetSymbolAddress "_reset"`
