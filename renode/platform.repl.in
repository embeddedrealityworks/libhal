// Renode platform description for @mcu_name@
// Generated by Meson configure_file from cross-file properties — do not edit

nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xF0
    systickFrequency: @sysclk_hz@

cpu: CPU.CortexM @ sysbus
    cpuType: "@mcu_core@"
    nvic: nvic

flash: Memory.MappedMemory @ sysbus @flash_origin@
    size: @flash_bytes@

sram: Memory.MappedMemory @ sysbus @ram_origin@
    size: @ram_bytes@
